# Copiá este archivo como .env.local y completá con tus valores.

# --- Supabase (cliente) ---  (Supabase → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_public_key

# --- IA (SERVIDOR, opcional) --- (https://console.anthropic.com)
# Sin esta clave, la app igual funciona usando estimaciones locales.
# NO lleva prefijo NEXT_PUBLIC_ para que nunca llegue al navegador.
ANTHROPIC_API_KEY=tu_clave_anthropic
AI_MODEL=claude-3-5-sonnet-latest
